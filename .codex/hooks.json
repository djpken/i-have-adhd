{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/inject-skill.js",
            "timeout": 5,
            "statusMessage": "Loading ADHD-friendly output mode..."
          }
        ]
      }
    ]
  }
}
